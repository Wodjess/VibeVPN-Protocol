{
  "expo": {
    "name": "VibeVPN",
    "slug": "vibevpn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibevpn.app",
      "infoPlist": {
        "UIBackgroundModes": ["network-authentication"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "package": "com.vibevpn.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "./modules/expo-vpn/plugin"
    ]
  }
}
